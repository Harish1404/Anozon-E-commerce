            {"$match": {"items.seller_id": seller_id}},
            {"$unwind": "$items"},
            {"$match": {"items.seller_id": seller_id}},
            {"$match": {"items.status": {"$nin": ["cancelled"]}}},
            {"$sort": {"created_at": -1}},
            
